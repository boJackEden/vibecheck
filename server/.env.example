# Anthropic API key — the server calls Claude to generate + grade quizzes
ANTHROPIC_API_KEY=sk-ant-...

# Port the server listens on (Railway sets PORT automatically)
PORT=3000

# Model + quiz tuning (optional)
QUIZ_MODEL=claude-opus-4-8
QUIZ_PASS_RATIO=0.7

# Security: comma-separated GitHub owners/orgs allowed to call /quiz/*.
# Workflows in these owners' repos authenticate via GitHub Actions OIDC — no
# shared secret needed. If unset, /quiz/* is UNAUTHENTICATED (local dev only).
# Example: QUIZ_ALLOWED_OWNERS=boJackEden,my-work-org
QUIZ_ALLOWED_OWNERS=
# Must match the audience the workflow requests (default: pr-quiz)
QUIZ_OIDC_AUDIENCE=pr-quiz
