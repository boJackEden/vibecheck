# Anthropic API key — the server calls Claude to generate + grade quizzes
ANTHROPIC_API_KEY=sk-ant-...

# Port the server listens on (Railway sets PORT automatically)
PORT=3000

# Model + quiz tuning (optional)
VIBECHECK_MODEL=claude-opus-4-8
VIBECHECK_PASS_RATIO=0.7

# Security: comma-separated GitHub owners/orgs allowed to call /vibecheck/*.
# Workflows in these owners' repos authenticate via GitHub Actions OIDC — no
# shared secret needed. If unset, /vibecheck/* is UNAUTHENTICATED (local dev only).
# Example: VIBECHECK_ALLOWED_OWNERS=boJackEden,my-work-org
VIBECHECK_ALLOWED_OWNERS=
# Must match the audience the workflow requests (default: vibecheck)
VIBECHECK_OIDC_AUDIENCE=vibecheck
